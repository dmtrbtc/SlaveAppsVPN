# SLAVE VPN — Environment Variables Example
# Copy to .env.local and fill in your values
# .env.local is gitignored and must NEVER be committed

# Cabinet API base URL (Remnawave backend)
VITE_API_BASE_URL=https://api.your-domain.com

# Electron log level: error | warn | info | debug | trace
ELECTRON_LOG_LEVEL=info

# Mihomo REST API port (default: 9090, randomized at runtime)
# MIHOMO_API_PORT=9090

# Development flags
# VITE_DEV_TOOLS=true
