{
  "extends": "@slave-vpn/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "verbatimModuleSyntax": false,
    "lib": ["ES2022", "DOM"],
    "outDir": "dist/cjs",
    "rootDir": "src",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false
  },
  "include": ["src"]
}
